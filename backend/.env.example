OPEN_AI_API_KEY=your_openai_api_key_here
DATABASE_URL=postgresql://user:password@localhost:5432/contex_dev
# Use 4001 if another app (e.g. shotless-api) already listens on 4000
PORT=4001
# Comma-separated: Next.js + Expo dev server
CORS_ORIGIN=http://localhost:3000,http://localhost:8081

# ─────────────────────────────────────────────────────────────
# Auth (org login) — generate strong random values, e.g.
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# ─────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
# Public base URL of the web app (used for OAuth redirects back to the dashboard)
WEB_APP_URL=http://localhost:3000

# AES-256-GCM key for encrypting stored social tokens at rest.
# MUST be 32 bytes, base64-encoded:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=change_me_32_byte_base64_key

# ─────────────────────────────────────────────────────────────
# Meta (Facebook / Instagram) — https://developers.facebook.com/apps
# Add META_REDIRECT_URI as a valid OAuth redirect URI in the app settings.
# ─────────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:4001/api/integrations/meta/callback
META_GRAPH_VERSION=v21.0

# ─────────────────────────────────────────────────────────────
# Google Analytics (GA4) — https://console.cloud.google.com/apis/credentials
# Enable: Google Analytics Data API + Google Analytics Admin API.
# Add GOOGLE_REDIRECT_URI as an authorized redirect URI on the OAuth client.
# ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4001/api/integrations/google/callback

# Set to true to return hardcoded pipeline (no OpenAI). Omit or false for live AI.
USE_MOCK_PIPELINE=false

# Stock background search (configure at least one for best results)
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=

# Replicate — https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
# Use owner/name:version — unpinned names 404 on the models API
REPLICATE_DEFAULT_MODEL=google/imagen-4:19335492dbe879d4b5983bff2149f597db8314ccc7fe374e6313af7c2b52792f
REPLICATE_BG_MODEL=851-labs/background-remover:a029dff38972b5fda4ec5d75d7d1cd25aeff621d2cf4946a41055d7db66b80bc
# flux-kontext-pro: sends original photo as input_image + text prompt (recommended)
# google/imagen-4: prompt only (text-to-image; original photo is not sent to Replicate)
REPLICATE_CLOTHING_MODEL=black-forest-labs/flux-kontext-pro:03ada98f518905f4c7df5150c361338a683845249550af5ed21dc449be56d500
REPLICATE_GENERATION_MODEL=black-forest-labs/flux-kontext-pro:03ada98f518905f4c7df5150c361338a683845249550af5ed21dc449be56d500
