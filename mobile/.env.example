# Same as web NEXT_PUBLIC_API_URL — points at the Express API, not Replicate.
# Replicate keys belong in backend/.env only.

# iOS simulator / backend on this Mac:
API_BASE_URL=http://localhost:4000

# Physical device on same Wi‑Fi (use your Mac's LAN IP):
# API_BASE_URL=http://192.168.1.10:4000

# Override at run time (optional):
# flutter run --dart-define=API_BASE_URL=http://192.168.1.10:4000
